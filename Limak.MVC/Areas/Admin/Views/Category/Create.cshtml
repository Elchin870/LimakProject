@model CategoryCreateDto

<style>
    .page-container {
        padding: 30px 20px;
    }

    .form-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 30px;
    }

    .form-title {
        font-size: 28px;
        font-weight: 700;
        color: #2c3e50;
        margin: 0;
    }

    .form-title i {
        color: #1abc9c;
        font-size: 32px;
    }

    .form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        max-width: 700px;
    }

    .form-card-header {
        background: linear-gradient(135deg, #1abc9c 0%, #16a085 100%);
        color: white;
        padding: 24px;
        font-size: 16px;
        font-weight: 600;
    }

    .form-card-body {
        padding: 40px;
    }

    .form-group {
        margin-bottom: 28px;
    }

    .form-group:last-child {
        margin-bottom: 0;
    }

    .form-label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-input {
        width: 100%;
        padding: 14px 16px;
        border: 2px solid #e8eef5;
        border-radius: 8px;
        font-size: 14px;
        color: #2c3e50;
        transition: all 0.3s ease;
        font-family: inherit;
        background: #f8f9fb;
    }

    .form-input:focus {
        outline: none;
        border-color: #1abc9c;
        background: white;
        box-shadow: 0 0 0 3px rgba(26, 188, 156, 0.1);
    }

    .form-input::placeholder {
        color: #95a5a6;
    }

    .validation-summary {
        background: #f8d7da;
        border-left: 4px solid #dc3545;
        padding: 16px;
        border-radius: 6px;
        margin-bottom: 24px;
        animation: slideDown 0.3s ease-out;
    }

    .validation-summary ul {
        margin: 0;
        padding-left: 20px;
    }

    .validation-summary li {
        color: #721c24;
        font-size: 13px;
        margin-bottom: 6px;
    }

    .validation-summary li:last-child {
        margin-bottom: 0;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .field-error {
        color: #dc3545;
        font-size: 12px;
        margin-top: 6px;
        display: block;
        animation: fadeIn 0.3s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    .form-input.is-invalid {
        border-color: #dc3545;
        background: #fff8f8;
    }

    .form-actions {
        display: flex;
        gap: 16px;
        margin-top: 40px;
        padding-top: 24px;
        border-top: 1px solid #e8eef5;
        flex-wrap: wrap;
    }

    .btn-submit {
        background: linear-gradient(135deg, #1abc9c 0%, #16a085 100%);
        color: white;
        padding: 14px 40px;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(26, 188, 156, 0.4);
        color: white;
    }

    .btn-submit:active {
        transform: translateY(0);
    }

    .btn-cancel {
        background: white;
        color: #1abc9c;
        padding: 14px 40px;
        border: 2px solid #1abc9c;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-cancel:hover {
        background: #f0fdf9;
        transform: translateY(-2px);
        color: #1abc9c;
    }

    .form-info {
        background: #d1f2eb;
        border-left: 4px solid #1abc9c;
        padding: 16px;
        border-radius: 6px;
        font-size: 13px;
        color: #0f766e;
        margin-bottom: 28px;
    }

    .form-info i {
        margin-right: 8px;
    }

    @@media (max-width: 600px) {
        .page-container {
            padding: 20px 16px;
        }

        .form-card-body {
            padding: 24px;
        }

        .form-title {
            font-size: 22px;
        }

        .form-actions {
            flex-direction: column;
        }

        .btn-submit,
        .btn-cancel {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="page-container">
    <!-- Form Header -->
    <div class="form-header">
        <h1 class="form-title">
            <i class="mdi mdi-folder-plus"></i>
            Yeni Kateqoriya Yaradın
        </h1>
    </div>

    <!-- Form Card -->
    <div class="form-card">
        <div class="form-card-header">
            <i class="mdi mdi-information-outline" style="margin-right: 8px;"></i>
            Aşağıda kateqoriya detallarını daxil edin
        </div>

        <div class="form-card-body">
            <!-- Info Alert -->
            <div class="form-info">
                <i class="mdi mdi-lightbulb-outline"></i>
                Lütfən, kateqoriyanız üçün unikal və təsviri bir ad təmin edin.
            </div>

            <!-- Form -->
            <form method="post" asp-area="Admin" asp-controller="Category" asp-action="Create">
                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <!-- Category Name Field -->
                <div class="form-group">
                    <label asp-for="Name" class="form-label">
                        <i class="mdi mdi-tag" style="margin-right: 6px;"></i>
                        Kateqoriyanın Adı
                    </label>
                    <input asp-for="Name" class="form-input" placeholder="Kateqoriyanın adını daxil edin (məs.: Elektronika, Moda)">
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-submit">
                        <i class="mdi mdi-check"></i>
                        Kateqoriya Yaradın
                    </button>
                    <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn-cancel">
                        <i class="mdi mdi-close"></i>
                        Ləğv Et
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
