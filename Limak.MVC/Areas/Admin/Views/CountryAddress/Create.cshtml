@using Limak.Application.Dtos.CountryDtos
@model CountryAddressCreateDto

<style>
    .page-container {
        padding: 30px 20px;
    }

    .form-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 30px;
    }

    .form-title {
        font-size: 28px;
        font-weight: 700;
        color: #2c3e50;
        margin: 0;
    }

    .form-title i {
        color: #1abc9c;
        font-size: 32px;
    }

    .form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        max-width: 700px;
    }

    .form-card-header {
        background: linear-gradient(135deg, #1abc9c 0%, #16a085 100%);
        color: white;
        padding: 24px;
        font-size: 16px;
        font-weight: 600;
    }

    .form-card-body {
        padding: 40px;
    }

    .form-group {
        margin-bottom: 28px;
    }

    .form-group:last-child {
        margin-bottom: 0;
    }

    .form-label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-input,
    .form-select {
        width: 100%;
        padding: 14px 16px;
        border: 2px solid #e8eef5;
        border-radius: 8px;
        font-size: 14px;
        color: #2c3e50;
        transition: all 0.3s ease;
        font-family: inherit;
        background: #f8f9fb;
    }

    .form-input:focus,
    .form-select:focus {
        outline: none;
        border-color: #1abc9c;
        background: white;
        box-shadow: 0 0 0 3px rgba(26, 188, 156, 0.1);
    }

    .form-input::placeholder {
        color: #95a5a6;
    }

    .form-select option {
        color: #2c3e50;
        background: white;
    }

    .validation-summary {
        background: #f8d7da;
        border-left: 4px solid #dc3545;
        padding: 16px;
        border-radius: 6px;
        margin-bottom: 24px;
        animation: slideDown 0.3s ease-out;
    }

    .validation-summary ul {
        margin: 0;
        padding-left: 20px;
    }

    .validation-summary li {
        color: #721c24;
        font-size: 13px;
        margin-bottom: 6px;
    }

    .validation-summary li:last-child {
        margin-bottom: 0;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .field-error {
        color: #dc3545;
        font-size: 12px;
        margin-top: 6px;
        display: block;
        animation: fadeIn 0.3s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    .form-input.is-invalid,
    .form-select.is-invalid {
        border-color: #dc3545;
        background: #fff8f8;
    }

    .form-actions {
        display: flex;
        gap: 16px;
        margin-top: 40px;
        padding-top: 24px;
        border-top: 1px solid #e8eef5;
        flex-wrap: wrap;
    }

    .btn-submit {
        background: linear-gradient(135deg, #1abc9c 0%, #16a085 100%);
        color: white;
        padding: 14px 40px;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(26, 188, 156, 0.4);
        color: white;
    }

    .btn-submit:active {
        transform: translateY(0);
    }

    .btn-cancel {
        background: white;
        color: #1abc9c;
        padding: 14px 40px;
        border: 2px solid #1abc9c;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-cancel:hover {
        background: #f0fdf9;
        transform: translateY(-2px);
        color: #1abc9c;
    }

    .form-info {
        background: #d1f2eb;
        border-left: 4px solid #1abc9c;
        padding: 16px;
        border-radius: 6px;
        font-size: 13px;
        color: #0f766e;
        margin-bottom: 28px;
    }

    .form-info i {
        margin-right: 8px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    @@media (max-width: 600px) {
        .page-container {
            padding: 20px 16px;
        }

        .form-card-body {
            padding: 24px;
        }

        .form-title {
            font-size: 22px;
        }

        .form-actions {
            flex-direction: column;
        }

        .btn-submit,
        .btn-cancel {
            width: 100%;
            justify-content: center;
        }

        .form-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-container">
    <!-- Form Header -->
    <div class="form-header">
        <h1 class="form-title">
            <i class="mdi mdi-map-marker-plus"></i>
            Yeni Ölkə Ünvanı Yaradın
        </h1>
    </div>

    <!-- Form Card -->
    <div class="form-card">
        <div class="form-card-header">
            <i class="mdi mdi-information-outline" style="margin-right: 8px;"></i>
            Aşağıda ünvan detallarını daxil edin
        </div>

        <div class="form-card-body">
            <!-- Info Alert -->
            <div class="form-info">
                <i class="mdi mdi-lightbulb-outline"></i>
                Lütfən şəhər, əyalət, ölkə və ünvan daxil olmaqla tam ünvan məlumatını təmin edin.
            </div>

            <!-- Form -->
            <form method="post" asp-area="Admin" asp-controller="CountryAddress" asp-action="Create">
                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <!-- City and State Row -->
                <div class="form-row">
                    <!-- City Field -->
                    <div class="form-group">
                        <label asp-for="City" class="form-label">
                            <i class="mdi mdi-city" style="margin-right: 6px;"></i>
                            Şəhər
                        </label>
                        <input asp-for="City" class="form-input" placeholder="Şəhərin adını daxil edin">
                        <span asp-validation-for="City" class="field-error"></span>
                    </div>

                    <!-- State Field -->
                    <div class="form-group">
                        <label asp-for="State" class="form-label">
                            <i class="mdi mdi-map" style="margin-right: 6px;"></i>
                            Əyalət / Bölgə
                        </label>
                        <input asp-for="State" class="form-input" placeholder="Əyalət və ya bölgəni daxil edin">
                        <span asp-validation-for="State" class="field-error"></span>
                    </div>
                </div>

                <!-- Country Field -->
                <div class="form-group">
                    <label asp-for="CountryId" class="form-label">
                        <i class="mdi mdi-earth" style="margin-right: 6px;"></i>
                        Ölkə
                    </label>
                    <select asp-for="CountryId" class="form-select">
                        <option value="">-- Ölkə Seçin --</option>
                        @if (ViewBag.Countries is List<CountryGetDto> countries)
                        {
                            @foreach (var country in countries)
                            {
                                <option value="@country.Id">@country.Name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CountryId" class="field-error"></span>
                </div>

                <!-- Address Field -->
                <div class="form-group">
                    <label asp-for="Address" class="form-label">
                        <i class="mdi mdi-home" style="margin-right: 6px;"></i>
                        Küçə Ünvanı
                    </label>
                    <input asp-for="Address" class="form-input" placeholder="Tam küçə ünvanını daxil edin">
                    <span asp-validation-for="Address" class="field-error"></span>
                </div>

                <!-- TC (Postal Code) Field -->
                <div class="form-group">
                    <label asp-for="TC" class="form-label">
                        <i class="mdi mdi-mail" style="margin-right: 6px;"></i>
                        Poçt Kodu / TC (İsteğe bağlı)
                    </label>
                    <input asp-for="TC" class="form-input" placeholder="Poçt kodunu və ya TC-ni daxil edin">
                    <span asp-validation-for="TC" class="field-error"></span>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-submit">
                        <i class="mdi mdi-check"></i>
                        Ünvan Yaradın
                    </button>
                    <a asp-area="Admin" asp-controller="CountryAddress" asp-action="Index" class="btn-cancel">
                        <i class="mdi mdi-close"></i>
                        Ləğv Et
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
