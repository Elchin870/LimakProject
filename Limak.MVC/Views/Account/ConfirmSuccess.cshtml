@{
    ViewData["Title"] = "Email Təsdiqləndi";
}

<style>
    .confirm-page-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 20px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .confirm-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        padding: 50px 40px;
        text-align: center;
        max-width: 500px;
        width: 100%;
        animation: slideUp 0.6s ease-out;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .success-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 30px;
        animation: scaleIn 0.6s ease-out 0.2s both;
    }

    @@keyframes scaleIn {
        from {
            transform: scale(0);
        }

        to {
            transform: scale(1);
        }
    }

    .success-icon::before {
        content: '✓';
        color: white;
        font-size: 48px;
        font-weight: bold;
    }

    .confirm-title {
        font-size: 28px;
        font-weight: 700;
        color: #2d3748;
        margin: 0 0 15px 0;
        animation: fadeIn 0.6s ease-out 0.3s both;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .confirm-message {
        font-size: 16px;
        color: #718096;
        line-height: 1.6;
        margin-bottom: 15px;
        animation: fadeIn 0.6s ease-out 0.4s both;
    }

    .confirm-message-content {
        background-color: #f0f4ff;
        border-left: 4px solid #667eea;
        padding: 15px;
        border-radius: 6px;
        text-align: left;
        font-weight: 500;
        color: #2d3748;
        margin: 20px 0;
        animation: fadeIn 0.6s ease-out 0.5s both;
    }

    .confirm-description {
        font-size: 14px;
        color: #a0aec0;
        margin-bottom: 30px;
        animation: fadeIn 0.6s ease-out 0.6s both;
    }

    .button-group {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
        animation: fadeIn 0.6s ease-out 0.7s both;
    }

    .btn-primary-confirm {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 40px;
        border: none;
        border-radius: 6px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
    }

        .btn-primary-confirm:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
            color: white;
        }

    .btn-secondary-confirm {
        background: white;
        color: #667eea;
        padding: 12px 40px;
        border: 2px solid #667eea;
        border-radius: 6px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
    }

        .btn-secondary-confirm:hover {
            background: #f0f4ff;
            transform: translateY(-2px);
            color: #667eea;
        }

    .confirm-footer {
        font-size: 12px;
        color: #cbd5e0;
        margin-top: 30px;
        border-top: 1px solid #e2e8f0;
        padding-top: 20px;
    }

    @@media (max-width: 600px) {
        .confirm-card {
            padding: 30px 20px;
        }

        .confirm-title {
            font-size: 24px;
        }

        .confirm-message {
            font-size: 14px;
        }

        .button-group {
            flex-direction: column;
        }

        .btn-primary-confirm,
        .btn-secondary-confirm {
            width: 100%;
        }
    }
</style>

<div class="confirm-page-container">
    <div class="confirm-card">
        <div class="success-icon"></div>

        <h1 class="confirm-title">Email Təsdiqləndi!</h1>

        <p class="confirm-message">
            Sizin hesabınız uğurlu şəkildə aktivləşdirilmişdir. Artıq giriş edə bilərsiz.
        </p>

        @if (!string.IsNullOrEmpty(Model as string))
        {
            <div class="confirm-message-content">
                @(Model as string)
            </div>
        }

        <p class="confirm-description">
            Xoş gəldiniz! Limak.az ilə xidmətlərimizə başlayın.
        </p>

        <div class="button-group">
            <a href="@Url.Action("Login", "Account")" class="btn-primary-confirm">
                Giriş Et
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn-secondary-confirm">
                Ana Səhifə
            </a>
        </div>

    </div>
</div>
