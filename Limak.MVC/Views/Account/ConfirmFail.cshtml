@{
    ViewData["Title"] = "Email Təsdiqlənməsi Uğursuz";
}

<style>
    .confirm-page-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        padding: 20px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .confirm-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        padding: 50px 40px;
        text-align: center;
        max-width: 500px;
        width: 100%;
        animation: slideUp 0.6s ease-out;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .error-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 30px;
        animation: scaleIn 0.6s ease-out 0.2s both;
    }

    @@keyframes scaleIn {
        from {
            transform: scale(0);
        }
        to {
            transform: scale(1);
        }
    }

    .error-icon::before {
        content: '✕';
        color: white;
        font-size: 48px;
        font-weight: bold;
    }

    .confirm-title {
        font-size: 28px;
        font-weight: 700;
        color: #2d3748;
        margin: 0 0 15px 0;
        animation: fadeIn 0.6s ease-out 0.3s both;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    .confirm-message {
        font-size: 16px;
        color: #718096;
        line-height: 1.6;
        margin-bottom: 15px;
        animation: fadeIn 0.6s ease-out 0.4s both;
    }

    .confirm-message-content {
        background-color: #fff5f5;
        border-left: 4px solid #f5576c;
        padding: 15px;
        border-radius: 6px;
        text-align: left;
        font-weight: 500;
        color: #c53030;
        margin: 20px 0;
        animation: fadeIn 0.6s ease-out 0.5s both;
    }

    .confirm-description {
        font-size: 14px;
        color: #a0aec0;
        margin-bottom: 30px;
        animation: fadeIn 0.6s ease-out 0.6s both;
    }

    .button-group {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
        animation: fadeIn 0.6s ease-out 0.7s both;
    }

    .btn-primary-confirm {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
        padding: 12px 40px;
        border: none;
        border-radius: 6px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
    }

    .btn-primary-confirm:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(245, 87, 108, 0.4);
        color: white;
    }

    .btn-secondary-confirm {
        background: white;
        color: #f5576c;
        padding: 12px 40px;
        border: 2px solid #f5576c;
        border-radius: 6px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
    }

    .btn-secondary-confirm:hover {
        background: #fff5f5;
        transform: translateY(-2px);
        color: #f5576c;
    }

    .confirm-footer {
        font-size: 12px;
        color: #cbd5e0;
        margin-top: 30px;
        border-top: 1px solid #e2e8f0;
        padding-top: 20px;
    }

    .info-box {
        background-color: #fef5e7;
        border-left: 4px solid #f39c12;
        padding: 15px;
        border-radius: 6px;
        margin: 20px 0;
        text-align: left;
        font-size: 13px;
        color: #7d6608;
        animation: fadeIn 0.6s ease-out 0.6s both;
    }

    @@media (max-width: 600px) {
        .confirm-card {
            padding: 30px 20px;
        }

        .confirm-title {
            font-size: 24px;
        }

        .confirm-message {
            font-size: 14px;
        }

        .button-group {
            flex-direction: column;
        }

        .btn-primary-confirm,
        .btn-secondary-confirm {
            width: 100%;
        }
    }
</style>

<div class="confirm-page-container">
    <div class="confirm-card">
        <div class="error-icon"></div>
        
        <h1 class="confirm-title">Təsdiqlənmə Uğursuz Oldu!</h1>
        
        <p class="confirm-message">
            Maalesef, email adresinizi təsdiqləmək mümkün olmadı.
        </p>

        @if (!string.IsNullOrEmpty(Model as string))
        {
            <div class="confirm-message-content">
                @(Model as string)
            </div>
        }

        <div class="info-box">
            <strong>Nə edə bilərsiz:</strong>
            <ul style="margin: 10px 0 0 20px; padding: 0;">
                <li>Təsdiq linkini yenidən göndərməyi xahiş edin</li>
                <li>Yeni hesab qeydiyyatından keçin</li>
                <li>Bizim dəstək komandasına qoşulun</li>
            </ul>
        </div>

        <div class="button-group">
            <a href="@Url.Action("Register", "Account")" class="btn-primary-confirm">
                Yenidən Qeydiyyatdan Keçin
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn-secondary-confirm">
                Ana Səhifəyə Qayıt
            </a>
        </div>


    </div>
</div>
