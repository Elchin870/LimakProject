@model RegisterViewModel
<!-- Main Start -->
<main id="main"
      style="background: url(~/assets/images/limak_bg.jpg) no-repeat; background-size: 100%; background-position: top center;"
      class="bg-full">
    <div class="main-container">
        <div class="register">
            <div class="block">
                <!-- Block Header -->
                <div class="block-header">
                    <h2 class="title page-title">İSTİFADƏÇİ QEYDİYYATI</h2>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a asp-controller="Home" asp-action="Index">Ana səhifə</a>
                        </li>
                        <li class="breadcrumb-item active">
                            <span>QEYDİYYAT</span>
                        </li>
                    </ul>
                </div>
                <div class="block-body">
                    <div class="card card-auth card-reg mb-20">
                        <div class="card-auth-header">
                            <h1 class="card-auth-title upper">
                                İSTİFADƏÇİ QEYDİYYATI
                            </h1>
                        </div>
                        <form asp-controller="Account" asp-action="Register" method="post" class="form-reg">
                            <div asp-validation-summary="All" class="text-danger"></div>
                            <div class="row">
                                <div class="col-md-12 col-12">
                                    <h3 class="form-title">
                                        Profil məlumatları
                                    </h3>
                                    <div class="row">
                                        <div class="col-6">
                                            <input asp-for="Register.FirstName" id="reg-name" type="text" placeholder="Ad" required="required"
                                                   autocomplete="none" aria-required="true" class="form-control">
                                        </div>
                                        <div class="col-6">
                                            <input asp-for="Register.LastName" id="reg-name" type="text" placeholder="Soyad" required="required"
                                                   autocomplete="none" aria-required="true" class="form-control">
                                        </div>
                                        <div class="col-6">
                                            <input asp-for="Register.UserName" id="reg-name" type="text" placeholder="UserName" required="required"
                                                   autocomplete="none" aria-required="true" class="form-control">
                                        </div>
                                        <div class="col-6">
                                            <input asp-for="Register.Email" id="reg-name" type="email" placeholder="E-mail"
                                                   required="required" autocomplete="none" aria-required="true"
                                                   class="form-control">
                                        </div>
                                        <div class="col-6">
                                            <input asp-for="Register.PhoneNumber" id="reg-name" type="tel"
                                                   placeholder="Telefon" required
                                                   autocomplete="tel" aria-required="true"
                                                   class="form-control">
                                        </div>

                                        <div class="pass col-md-6 col-12">
                                            <input asp-for="Register.Password" id="password" type="password" placeholder="Şifrə"
                                                   required="required" autocomplete="new-password" aria-required="true"
                                                   class="form-control">
                                            <a class="visiblity-btn showPass">
                                                <span aria-hidden="true" class="show_p hide-eye"></span>
                                            </a>
                                        </div>
                                        <div class="pass col-md-6 col-12">
                                            <input asp-for="Register.ConfirmPassword" id="password_confirmation" type="password"
                                                   placeholder="Şifrənin təkrarı" required="required"
                                                   autocomplete="new-password" aria-required="true"
                                                   class="form-control">
                                            <a class="visiblity-btn showPass">
                                                <span aria-hidden="true" class="show_p hide-eye"></span>
                                            </a>
                                        </div>
                                        <div class="col-12">
                                            <select asp-for="Register.OfficeId" id="deliveryOfiice" class="custom-select">
                                                @foreach (var office in Model.Offices)
                                                {
                                                    <option value="@office.Id">
                                                        @office.City
                                                        @if (!string.IsNullOrWhiteSpace(office.MetroStation))
                                                        {
                                                            @: - @office.MetroStation
                                                        }
                                                    </option>
                                                }

                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="form-reg-footer">
                                <button type="submit" class="btn btn-submit form-reg-btn btn-primary">
                                    <span>QEYDİYYAT</span>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
<!-- Main End -->
