@model Limak.Application.Dtos.OrderDtos.UserOrderCreateDto

@{
    ViewData["Title"] = "Yeni Sifariş Yaradın";
}

<div style="margin-top: 150px; margin-bottom: 50px;">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <!-- Header Section -->
                <div style="margin-bottom: 40px;">
                    <h1 style="font-size: 32px; font-weight: 700; color: #222; margin-bottom: 10px;">
                        Yeni Sifariş Yaradın
                    </h1>

                </div>

                <!-- Form Card -->
                <div style="background: #fff; border-radius: 16px; padding: 40px; box-shadow: 0 8px 25px rgba(0,0,0,0.08);">

                    <!-- Error Messages -->
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div style="background: #fee; border-left: 4px solid #dc3545; border-radius: 8px; padding: 15px; margin-bottom: 25px; color: #721c24;">
                            <strong>Xəta baş verdi!</strong>
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                @foreach (var error in modelState.Errors)
                                {
                                    <div style="margin-top: 5px;">• @error.ErrorMessage</div>
                                }
                            }
                        </div>
                    }

                    <form method="post" asp-action="Create" asp-controller="UserPanel">
                        <!-- Country Selection -->
                        <div style="margin-bottom: 30px;">
                            <label asp-for="CountryId" style="display: block; font-weight: 600; color: #222; margin-bottom: 10px; font-size: 14px;">
                                Ölkə Seçin <span style="color: #dc3545;">*</span>
                            </label>
                            <select asp-for="CountryId"
                                    class="form-control"
                                    id="countrySelect"
                                    style="height: 48px; border: 2px solid #e0e0e0; border-radius: 8px; padding: 12px; font-size: 14px; font-weight: 500; transition: all 0.3s ease;"
                                    onchange="this.style.borderColor=this.value?'#28a745':'#e0e0e0'"
                                    required>
                                <option value="">-- Ölkə Seçin --</option>
                            </select>
                            <span asp-validation-for="CountryId" style="color: #dc3545; font-size: 13px; margin-top: 5px; display: block;"></span>
                        </div>

                        <!-- Store Name -->
                        <div style="margin-bottom: 30px;">
                            <label asp-for="StoreName" style="display: block; font-weight: 600; color: #222; margin-bottom: 10px; font-size: 14px;">
                                Mağaza Adı <span style="color: #dc3545;">*</span>
                            </label>
                            <input asp-for="StoreName"
                                   type="text"
                                   class="form-control"
                                   placeholder="Mağaza adını daxil edin (məs: Amazon, eBay)"
                                   style="height: 48px; border: 2px solid #e0e0e0; border-radius: 8px; padding: 12px; font-size: 14px; transition: all 0.3s ease;"
                                   onfocus="this.style.borderColor='#28a745'; this.style.boxShadow='0 0 0 3px rgba(40,167,69,0.1)'"
                                   onblur="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none'"
                                   required />
                            <span asp-validation-for="StoreName" style="color: #dc3545; font-size: 13px; margin-top: 5px; display: block;"></span>
                        </div>

                        <!-- Store URL -->
                        <div style="margin-bottom: 30px;">
                            <label asp-for="StoreUrl" style="display: block; font-weight: 600; color: #222; margin-bottom: 10px; font-size: 14px;">
                                Məhsulun URL-i <span style="color: #dc3545;">*</span>
                            </label>
                            <input asp-for="StoreUrl"
                                   type="url"
                                   class="form-control"
                                   placeholder="https://example.com/product"
                                   style="height: 48px; border: 2px solid #e0e0e0; border-radius: 8px; padding: 12px; font-size: 14px; transition: all 0.3s ease;"
                                   onfocus="this.style.borderColor='#28a745'; this.style.boxShadow='0 0 0 3px rgba(40,167,69,0.1)'"
                                   onblur="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none'"
                                   required />
                            <span asp-validation-for="StoreUrl" style="color: #dc3545; font-size: 13px; margin-top: 5px; display: block;"></span>
                        </div>

                        <!-- Row for Quantity and Price -->
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
                            <!-- Quantity -->
                            <div>
                                <label asp-for="Quantity" style="display: block; font-weight: 600; color: #222; margin-bottom: 10px; font-size: 14px;">
                                    Miqdar (Ədəd) <span style="color: #dc3545;">*</span>
                                </label>
                                <input asp-for="Quantity"
                                       type="number"
                                       class="form-control"
                                       min="1"
                                       placeholder="1"
                                       style="height: 48px; border: 2px solid #e0e0e0; border-radius: 8px; padding: 12px; font-size: 14px; transition: all 0.3s ease;"
                                       onfocus="this.style.borderColor='#28a745'; this.style.boxShadow='0 0 0 3px rgba(40,167,69,0.1)'"
                                       onblur="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none'"
                                       required />
                                <span asp-validation-for="Quantity" style="color: #dc3545; font-size: 13px; margin-top: 5px; display: block;"></span>
                            </div>

                            <!-- Price -->
                            <div>
                                <label asp-for="PriceAzn" style="display: block; font-weight: 600; color: #222; margin-bottom: 10px; font-size: 14px;">
                                    Qiymət (AZN) <span style="color: #dc3545;">*</span>
                                </label>
                                <input asp-for="PriceAzn"
                                       type="number"
                                       class="form-control"
                                       min="0.01"
                                       step="0.01"
                                       placeholder="0.00"
                                       style="height: 48px; border: 2px solid #e0e0e0; border-radius: 8px; padding: 12px; font-size: 14px; transition: all 0.3s ease;"
                                       onfocus="this.style.borderColor='#28a745'; this.style.boxShadow='0 0 0 3px rgba(40,167,69,0.1)'"
                                       onblur="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none'"
                                       required />
                                <span asp-validation-for="PriceAzn" style="color: #dc3545; font-size: 13px; margin-top: 5px; display: block;"></span>
                            </div>
                        </div>

                        <!-- Info Box -->
                        <div style="background: #f0f8ff; border-left: 4px solid #0066cc; border-radius: 8px; padding: 15px; margin-bottom: 30px; font-size: 13px; color: #0066cc;">
                            <strong>ℹ️ Məlumat:</strong> Sifariş yaradıldıqdan sonra məbləğ balansınızdan çıxılır və sifariş admin tərəfindən yoxlanılaraq təsdiq və ya ləğv edilir.
                        </div>

                        <!-- Buttons -->
                        <div style="display: flex; gap: 15px; justify-content: flex-end;">
                            <a href="@Url.Action("Index", "UserPanel")"
                               class="btn"
                               style="padding: 12px 30px; border: 2px solid #e0e0e0; border-radius: 8px; font-weight: 600; color: #666; background: transparent; text-decoration: none; transition: all 0.3s ease; cursor: pointer;"
                               onmouseover="this.style.borderColor='#dc3545'; this.style.color='#dc3545'"
                               onmouseout="this.style.borderColor='#e0e0e0'; this.style.color='#666'">
                                Ləğv et
                            </a>
                            <button type="submit"
                                    class="btn"
                                    style="padding: 12px 40px; background: #28a745; color: white; border: none; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 12px rgba(40,167,69,0.3);"
                                    onmouseover="this.style.background='#218838'; this.style.boxShadow='0 6px 16px rgba(40,167,69,0.4)'"
                                    onmouseout="this.style.background='#28a745'; this.style.boxShadow='0 4px 12px rgba(40,167,69,0.3)'">
                                Sifariş Yaradın
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Load countries on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadCountries();
        });

        async function loadCountries() {
            try {
                const response = await fetch('https://localhost:7078/api/Countries/get-all-countries');
                const data = await response.json();

                if (data.isSucceed && data.data) {
                    const select = document.getElementById('countrySelect');
                    data.data.forEach(country => {
                        const option = document.createElement('option');
                        option.value = country.id;
                        option.textContent = country.name;
                        select.appendChild(option);
                    });
                }
            } catch (error) {
                console.error('Error loading countries:', error);
            }
        }

        // Form validation on submit
        document.querySelector('form').addEventListener('submit', function(e) {
            const priceInput = document.querySelector('input[name="PriceAzn"]');
            const quantityInput = document.querySelector('input[name="Quantity"]');

            if (parseFloat(priceInput.value) <= 0) {
                e.preventDefault();
                alert('Qiymət 0-dan böyük olmalıdır');
                return false;
            }

            if (parseInt(quantityInput.value) < 1) {
                e.preventDefault();
                alert('Miqdar ən azı 1 olmalıdır');
                return false;
            }
        });
    </script>
}
