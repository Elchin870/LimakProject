@model ChangePasswordViewModel

<form method="post"
      asp-controller="Settings"
      asp-action="ChangePassword"
      class="form-safety">

    <div asp-validation-summary="ModelOnly"></div>

    <div class="row">
        <div class="col-lg-6 col-12">
            <div class="card-step">
                <h3 class="step-title upper">CARİ ŞİFRƏ</h3>

                <div role="group" class="input-group search">
                    <input asp-for="Password.CurrentPassword"
                           type="password"
                           placeholder="Şifrə"
                           class="form-control">

                    <div class="input-group-append">
                        <button type="button"
                                class="btn btn-info"
                                id="eyeBtn">
                            <i class="far fa-eye-slash"></i>
                        </button>
                    </div>
                </div>
            </div>

            <div class="card-step custom-card-step">
                <h3 class="step-title upper">YENİ ŞİFRƏ</h3>

                <input asp-for="Password.NewPassword"
                       type="password"
                       placeholder="Şifrə"
                       class="form-control">

                <input asp-for="Password.ConfirmNewPassword"
                       type="password"
                       placeholder="Təkrar şifrə"
                       class="form-control">
            </div>

            <button type="submit"
                    class="btn btn-submit btn-primary">
                <span>Yadda saxla</span>
            </button>
        </div>

        <div class="col-lg-6 col-12">
            <div class="form-password-info h100">
                <div class="text-center">
                    <img src="~/assets/images/safety.svg" alt="">
                </div>
            </div>
        </div>
    </div>
</form>