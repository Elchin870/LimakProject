@model UpdateCustomerViewModel

<form method="post"
      asp-controller="Settings"
      asp-action="UpdateCustomer"
      class="form-settings">

    <input type="hidden" asp-for="Customer.Id" />

    <div asp-validation-summary="ModelOnly"></div>

    <div class="row">
        <div class="col-6">
            <input asp-for="Customer.FirstName"
                   type="text"
                   placeholder="Ad"
                   class="form-control">
        </div>

        <div class="col-6">
            <input asp-for="Customer.LastName"
                   type="text"
                   placeholder="Soyad"
                   class="form-control">
        </div>

        <div class="col-6">
            <select asp-for="Customer.OfficeId"
                    class="custom-select">
                @foreach (var office in Model.Offices)
                {
                    <option value="@office.Id">
                        @office.City
                        @if (!string.IsNullOrWhiteSpace(office.MetroStation))
                        {
                            @: - @office.MetroStation
                        }
                    </option>
                }
            </select>
        </div>

        <div class="col-6">
            <input asp-for="Customer.UserName"
                   type="text"
                   readonly
                   placeholder="UserName"
                   class="form-control">
        </div>

        <div class="col-6">
            <input asp-for="Customer.Email"
                   type="text"
                   placeholder="Email"
                   class="form-control">
        </div>

        <div class="col-6">
            <input asp-for="Customer.PhoneNumber"
                   type="tel"
                   placeholder="Telefon Nömrəsi"
                   class="form-control">
        </div>

        <div class="col-6">
            <button type="submit"
                    class="btn btn-submit btn-primary">
                <span>Yadda saxla</span>
            </button>
        </div>
    </div>
</form>