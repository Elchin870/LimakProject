    @RenderSection("Scripts", required: false)

    <script>
        document.querySelectorAll(".delivery-btn")
            .forEach(btn => {

                btn.addEventListener("click", function (e) {

                    e.preventDefault();

                    let card = this.closest(".tariff-card-modern");

                    card.querySelectorAll(".delivery-btn")
                        .forEach(b => b.classList.remove("active"));

                    this.classList.add("active");

                    let type = this.dataset.delivery;

                    card.querySelectorAll(".delivery-section")
                        .forEach(sec => {

                            sec.style.display =
                                sec.dataset.section === type
                                ? "block"
                                : "none";
                        });
                });
            });
    </script>

    <script>
        document.querySelectorAll('.nav-item a').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();

                document.querySelectorAll('.nav-item a').forEach(a => a.classList.remove('active'));
                this.classList.add('active');

                const targetCategory = this.parentElement.getAttribute('data-target-item');

                document.querySelectorAll('.item-box').forEach(box => {
                    if (targetCategory === 'all' || box.getAttribute('data-item') === targetCategory) {
                        box.style.display = 'block';
                    } else {
                        box.style.display = 'none';
                    }
                });
            });
        });
    </script>

