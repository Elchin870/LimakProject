    <style>
        .tariff-card-modern {
            width: 420px;
            background: #fff;
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        }

        .tariff-header-modern {
            margin-bottom: 15px;
        }

            .tariff-header-modern h3 {
                font-size: 20px;
                font-weight: 600;
            }

        .delivery-toggle {
            display: flex;
            background: #f3f3f3;
            border-radius: 30px;
            padding: 5px;
            margin-bottom: 20px;
        }

        .delivery-btn {
            flex: 1;
            border: none;
            background: transparent;
            padding: 8px;
            border-radius: 25px;
            cursor: pointer;
            font-weight: 500;
        }

            .delivery-btn.active {
                background: #28a745;
                color: #fff;
            }

        .tariff-row-modern {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #f0f0f0;
        }

        .weight-col {
            font-weight: 600;
            font-size: 14px;
        }

        .price-col {
            display: flex;
            gap: 15px;
        }

        .price-box {
            background: #f9f9f9;
            padding: 6px 10px;
            border-radius: 8px;
            text-align: center;
        }

            .price-box span {
                display: block;
                font-size: 12px;
                color: #777;
            }

            .price-box strong {
                font-size: 14px;
            }

            .price-box.liquid {
                background: #eef6ff;
            }
    </style>
</head>

